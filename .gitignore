__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store
.env
.env.*
.claude/*
!.claude/nlpm.local.md

# VitePress site build artifacts
site/node_modules/
site/.vitepress/cache/
site/.vitepress/dist/
site/public/
# site/reference/*.md is auto-generated from canonical SKILL.md sources
# by bin/nlpm-build-reference-md. The deploy workflow regenerates it
# on every build, so the source-of-truth stays in skills/nlpm/*/SKILL.md
# rather than drifting between committed and deployed versions.
site/reference/*.md
# site/case-studies/ is a build-time copy of /case-studies/, with an
# auto-generated index page. Source of truth is /case-studies/ at repo
# root (where the auditor pipeline writes articles).
site/case-studies/
