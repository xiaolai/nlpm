__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store
.env
.env.*
.claude/*
!.claude/nlpm.local.md

# VitePress site build artifacts
site/node_modules/
site/.vitepress/cache/
site/.vitepress/dist/
site/public/
# site/reference/*.md is auto-generated from canonical SKILL.md sources
# by bin/nlpm-build-reference-md. The deploy workflow regenerates it
# on every build, so the source-of-truth stays in skills/nlpm/*/SKILL.md
# rather than drifting between committed and deployed versions.
site/reference/*.md
# site/case-studies/ is a build-time copy of /case-studies/, with an
# auto-generated index page. Source of truth is /case-studies/ at repo
# root (where the auditor pipeline writes articles).
site/case-studies/
# site/.vitepress/theme/data/ is build-time-copied from auditor/reports/*.json
# so Vue components can import the data via Vite's standard JSON import.
# Source of truth stays in auditor/reports/ (where the renderers write them).
site/.vitepress/theme/data/
# site/reports/*.md is build-time-generated from the JSON sidecars by
# bin/nlpm-build-site-report-pages. Source of truth is auditor/reports/.
site/reports/
# site/privacy.md is build-time-generated from PRIVACY.md at repo root
# by site/build.sh (a frontmatter is prepended). Source of truth stays
# at /PRIVACY.md so the policy is editable in one place.
site/privacy.md

# >>> cc-suite >>>
# cc-suite-schema: 3
# AI assistant local state
.claude/settings.local.json
.claude/CLAUDE.local.md
.claude/*.local.*
CLAUDE.local.md

# Codex CLI — local files, keep checked-in subdirs
.codex/*
!.codex/skills/
!.codex/prompts/
!.codex/hooks.json
!.codex/hooks.cc-suite.json
!.codex/config.toml

# Gemini CLI — local files, keep checked-in subdirs
.gemini/*
!.gemini/skills/
!.gemini/commands/

# cc-suite-managed symlinks (created by bridge_skills.sh) — derived, not authored
.claude/skills/cc-suite
.agents/skills

# cc-suite: plugin repo — keep the dev-only Codex MCP registration out of the
# published plugin. Claude Code auto-registers a plugin-root .mcp.json, which
# would start `codex mcp-server` for every installer. Local dev use is fine;
# the file just stays untracked.
.mcp.json
